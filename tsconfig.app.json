{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Only the types needed for the Next.js app (not Bun CLI tooling)
    "types": [
      "node"
    ],
    "jsx": "preserve"
  },
  "include": [
    "src/app/**/*",
    "src/lib/**/*",
    "src/db/**/*",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "tests"
  ]
}
